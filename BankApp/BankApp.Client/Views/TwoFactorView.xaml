<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankApp.Client.Views.TwoFactorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#1A1A2E" Padding="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="70" Height="70" CornerRadius="15" Background="#16213E" 
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <FontIcon Glyph="&#xE8D7;" FontSize="32" Foreground="#4ECDC4"/>
                </Border>
                <TextBlock Text="Security" FontSize="32" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Protecting your account." FontSize="14" 
                           Foreground="#888" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Padding="60">
            <StackPanel VerticalAlignment="Center" MaxWidth="360" HorizontalAlignment="Center">

                <TextBlock Text="Two-Factor Authentication" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Enter the 6-digit code sent to your device to continue." 
                           Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,30"/>

                <TextBox x:Name="OtpBox" PlaceholderText="000000" MaxLength="6"
                         Header="Authentication Code" Margin="0,0,0,20" CornerRadius="6"
                         TextAlignment="Center" FontSize="24" />

                <Button x:Name="VerifyButton" Content="VERIFY CODE" 
                        Click="VerifyButton_Click"
                        HorizontalAlignment="Stretch" Height="42"
                        Background="#4ECDC4" Foreground="White" FontWeight="SemiBold"
                        CornerRadius="6"/>

                <ProgressRing x:Name="LoadingRing" IsActive="False" 
                              Margin="0,16,0,0" Width="30" Height="30"
                              HorizontalAlignment="Center" Visibility="Collapsed"/>

                <InfoBar x:Name="ErrorInfoBar" IsOpen="False" Severity="Error"
                         Margin="0,16,0,0" IsClosable="True"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <HyperlinkButton x:Name="ResendButton" Content="Resend Code" 
                                     Click="ResendButton_Click" FontSize="13"/>
                    <TextBlock x:Name="CountdownText" Foreground="#888" FontSize="13" 
                               VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed"/>
                </StackPanel>

                <HyperlinkButton x:Name="BackToLoginButton" Content="Back to Login" 
                                 Click="BackToLoginButton_Click" HorizontalAlignment="Center" 
                                 Margin="0,20,0,0" FontSize="13" Foreground="#888"/>

            </StackPanel>
        </Grid>
    </Grid>
</Page>