<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankApp.Client.Views.ForgotPasswordView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#1A1A2E" Padding="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="70" Height="70" CornerRadius="15" Background="#16213E" 
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <FontIcon Glyph="&#xE8D4;" FontSize="32" Foreground="#4ECDC4"/>
                </Border>
                <TextBlock Text="Account Recovery" FontSize="32" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Get back into your account securely." FontSize="14" 
                           Foreground="#888" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Padding="60">
            <StackPanel VerticalAlignment="Center" MaxWidth="360" HorizontalAlignment="Center">

                <TextBlock Text="Reset Password" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock x:Name="InstructionText" 
                           Text="Enter your email address and we'll send you a code to reset your password." 
                           Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,30"/>

                <StackPanel x:Name="Step1Panel" Visibility="Visible">
                    <TextBox x:Name="EmailBox" PlaceholderText="you@company.com" 
                             Header="Email Address" Margin="0,0,0,20" CornerRadius="6"/>

                    <Button x:Name="SendCodeButton" Content="SEND RECOVERY CODE" 
                            Click="SendCodeButton_Click"
                            HorizontalAlignment="Stretch" Height="42"
                            Background="#4ECDC4" Foreground="White" FontWeight="SemiBold"
                            CornerRadius="6"/>
                </StackPanel>

                <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                    <TextBox x:Name="TokenBox" PlaceholderText="Paste the recovery code here" 
                             Header="Recovery Code" Margin="0,0,0,14" CornerRadius="6"/>

                    <Button x:Name="VerifyTokenButton" Content="VERIFY CODE" 
                            Click="VerifyTokenButton_Click"
                            HorizontalAlignment="Stretch" Height="42"
                            Background="#4ECDC4" Foreground="White" FontWeight="SemiBold"
                            CornerRadius="6" Margin="0,0,0,20"/>

                    <StackPanel x:Name="ResendPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="Didn't get the code?" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                        <HyperlinkButton x:Name="ResendCodeButton" Content="Resend it" 
                                         Click="ResendCodeButton_Click" FontSize="13" Margin="5,0,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="Step3Panel" Visibility="Collapsed">

                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="30" IsStaggeringEnabled="True"/>
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>

                        <PasswordBox x:Name="NewPasswordBox" PlaceholderText="••••••" 
                                     Header="New Password" Margin="0,0,0,14" CornerRadius="6"/>

                        <PasswordBox x:Name="ConfirmPasswordBox" PlaceholderText="••••••" 
                                     Header="Confirm New Password" Margin="0,0,0,20" CornerRadius="6"/>

                        <Button x:Name="ResetPasswordButton" Content="CONFIRM NEW PASSWORD" 
                                Click="ResetPasswordButton_Click"
                                HorizontalAlignment="Stretch" Height="42"
                                Background="#4ECDC4" Foreground="White" FontWeight="SemiBold"
                                CornerRadius="6"/>
                    </StackPanel>
                </StackPanel>

                <ProgressRing x:Name="LoadingRing" IsActive="False" 
                              Margin="0,16,0,0" Width="30" Height="30"
                              HorizontalAlignment="Center" Visibility="Collapsed"/>

                <InfoBar x:Name="StatusInfoBar" IsOpen="False" 
                         Margin="0,16,0,0" IsClosable="True"/>

                <HyperlinkButton x:Name="BackToLoginButton" Content="Back to Login" 
                                 Click="BackToLoginButton_Click" HorizontalAlignment="Center" 
                                 Margin="0,20,0,0" FontSize="13" Foreground="#888"/>

            </StackPanel>
        </Grid>
    </Grid>
</Page>