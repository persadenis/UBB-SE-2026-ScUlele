<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankApp.Client.Views.CardManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="RootPage"
    RequestedTheme="Light"
    Background="#F4F6FA">

    <Grid>
        <ScrollViewer x:Name="PageScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="28" Spacing="20">
                <InfoBar
                    IsOpen="{Binding IsStatusOpen, Mode=TwoWay}"
                    Severity="{Binding StatusSeverity}"
                    Message="{Binding StatusMessage}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="14" Margin="0,0,18,0">
                        <TextBlock Text="Card Management" FontSize="26" FontWeight="Bold" Foreground="#1A1A2E" />
                        <TextBlock Text="Manage card preferences, limits, and secure card detail reveal." Foreground="#5B6170" TextWrapping="Wrap" />

                        <Border Background="White" CornerRadius="16" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Sort Cards" FontWeight="SemiBold" />
                                <ComboBox
                                    ItemsSource="{Binding SortOptions}"
                                    DisplayMemberPath="Label"
                                    SelectedValuePath="Value"
                                    SelectedValue="{Binding SelectedSortOption, Mode=TwoWay}" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Content="Apply Sort" Command="{Binding ApplySortCommand}" />
                                    <Button Content="Refresh" Command="{Binding RefreshCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <ListView
                            x:Name="CardsList"
                            ItemsSource="{Binding Cards}"
                            SelectionMode="Single"
                            IsItemClickEnabled="True"
                            ItemClick="CardsList_ItemClick"
                            SelectionChanged="CardsList_SelectionChanged"
                            MinHeight="420"
                            Background="Transparent"
                            BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="16" Margin="0,0,0,12" Padding="16">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding CardholderName}" FontWeight="SemiBold" Foreground="#1A1A2E" />
                                            <TextBlock Text="{Binding MaskedCardNumber}" Foreground="#4E5566" />
                                            <TextBlock Text="{Binding AccountName}" Foreground="#4E5566" />
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="{Binding Status}" Foreground="#0F766E" />
                                                <TextBlock Text="{Binding CardBrand}" Foreground="#4E5566" />
                                                <TextBlock Text="{Binding ExpiryDate}" Foreground="#4E5566" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="16">
                        <Border Background="White" CornerRadius="20" Padding="22">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Selected Card" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E" />
                                <TextBlock
                                    x:Name="EmptyCardText"
                                    Text="Select a card to view its details."
                                    Foreground="#5B6170"
                                    TextWrapping="Wrap"
                                    Visibility="Collapsed" />

                                <StackPanel x:Name="SelectedCardDetailsPanel" Spacing="12">
                                    <TextBlock x:Name="CardholderNameText" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="Card Number" FontWeight="SemiBold" />
                                    <TextBlock x:Name="MaskedCardNumberText" Foreground="#4E5566" />
                                    <TextBlock Text="Account" FontWeight="SemiBold" />
                                    <TextBlock x:Name="AccountNameText" Foreground="#4E5566" />
                                    <TextBlock Text="Account IBAN" FontWeight="SemiBold" />
                                    <TextBlock x:Name="AccountIbanText" Foreground="#4E5566" TextWrapping="Wrap" />

                                    <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Status" FontWeight="SemiBold" />
                                        <TextBlock x:Name="StatusValueText" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Expiry" FontWeight="SemiBold" />
                                        <TextBlock x:Name="ExpiryValueText" />
                                    </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="20" Padding="22">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Controls" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E" />

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Spending Limit" FontWeight="SemiBold" />
                                    <TextBox
                                        x:Name="SpendingLimitBox"
                                        Text="{Binding SpendingLimitInput, Mode=TwoWay}"
                                        PlaceholderText="Enter monthly spending limit" />
                                </StackPanel>

                                <ToggleSwitch
                                    x:Name="OnlinePaymentsToggle"
                                    Header="Online Payments"
                                    Toggled="OnlinePaymentsToggle_Toggled" />

                                <ToggleSwitch
                                    x:Name="ContactlessPaymentsToggle"
                                    Header="Contactless Payments"
                                    Toggled="ContactlessPaymentsToggle_Toggled" />

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="FreezeCardButton" Content="Freeze Card" Command="{Binding FreezeCommand}" />
                                    <Button x:Name="UnfreezeCardButton" Content="Unfreeze Card" Command="{Binding UnfreezeCommand}" />
                                    <Button x:Name="SaveSettingsButton" Content="Save Settings" Command="{Binding SaveSettingsCommand}" />
                                    <Button x:Name="RevealDetailsButton" Content="Reveal Details" Click="RevealButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="SensitiveDetailsBorder" Background="#EEF6FF" CornerRadius="20" Padding="22" Visibility="{Binding SensitiveDetailsVisibility}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Sensitive Details" FontSize="18" FontWeight="Bold" Foreground="#102A43" />
                                <TextBlock x:Name="SensitiveCardNumberText" Text="{Binding RevealedCardNumber}" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="CVV" FontWeight="SemiBold" />
                                <TextBlock x:Name="SensitiveCvvText" Text="{Binding RevealedCvv}" />
                                <TextBlock x:Name="RevealCountdownTextBlock" Text="{Binding RevealCountdownText}" Foreground="#52606D" />
                                <Button Content="Hide Now" Command="{Binding HideSensitiveDetailsCommand}" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid Background="#80F4F6FA" Visibility="{Binding LoadingVisibility}">
            <ProgressRing Width="56" Height="56" IsActive="True" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
