<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankApp.Client.Views.NavView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <Style x:Key="NavItemStyle" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="20,10"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="CornerRadius"               Value="6"/>
            <Setter Property="Margin"                     Value="8,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root"
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#1A3A5C"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root"
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#152E4D"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Foreground="#AAA"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavItemActiveStyle" TargetType="Button">
            <Setter Property="Background"                 Value="#16213E"/>
            <Setter Property="BorderBrush"                Value="#4ECDC4"/>
            <Setter Property="BorderThickness"            Value="1.5"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="20,10"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="CornerRadius"               Value="6"/>
            <Setter Property="Margin"                     Value="8,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Foreground="White"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             SIDEBAR
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="#1A1A2E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo + Notification Bell -->
            <StackPanel Grid.Row="0" Padding="20,24,20,16">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="36" Height="36" CornerRadius="8" Background="#16213E">
                        <FontIcon Glyph="&#xE8AB;" FontSize="18" Foreground="#4ECDC4"/>
                    </Border>
                    <TextBlock Text="BankApp" FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>

                    <!-- Notification Bell with Badge -->
                    <Grid VerticalAlignment="Center" Margin="20,0,0,0"
                          PointerPressed="NotificationBell_PointerPressed">
                        <FontIcon Glyph="&#xEA8F;" FontSize="20" Foreground="#AAA"/>
                        <Border x:Name="NotificationBadge"
                                Width="18" Height="18" CornerRadius="9"
                                Background="#FF6B6B"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,-6,-6,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="NotificationBadgeText"
                                       Text="0" FontSize="10" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                </StackPanel>
            </StackPanel>

            <!-- Nav Items -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel Padding="0,8">

                    <Button x:Name="NavDashboard"
                            Style="{StaticResource NavItemActiveStyle}"
                            Click="NavDashboard_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE80F;" FontSize="14" Foreground="#4ECDC4"/>
                            <TextBlock Text="Dashboard" Foreground="White" FontSize="13"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavTransfers"
                            Style="{StaticResource NavItemStyle}"
                            Click="NavTransfers_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8AB;" FontSize="14" Foreground="#AAA"/>
                            <TextBlock Text="Transfers" Foreground="#AAA" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavBillPayments"
                            Style="{StaticResource NavItemStyle}"
                            Click="NavBillPayments_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8C7;" FontSize="14" Foreground="#AAA"/>
                            <TextBlock Text="Bill Payments" Foreground="#AAA" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavCards"
                            Style="{StaticResource NavItemStyle}"
                            Click="NavCards_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8C0;" FontSize="14" Foreground="#AAA"/>
                            <TextBlock Text="Cards" Foreground="#AAA" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavTransferHistory"
                            Style="{StaticResource NavItemStyle}"
                            Click="NavTransferHistory_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE81C;" FontSize="14" Foreground="#AAA"/>
                            <TextBlock Text="Transfer History" Foreground="#AAA" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavCurrencyExchange"
                            Style="{StaticResource NavItemStyle}"
                            Click="NavCurrencyExchange_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8B1;" FontSize="14" Foreground="#AAA"/>
                            <TextBlock Text="Currency Exchange" Foreground="#AAA" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavSavings"
                            Style="{StaticResource NavItemStyle}"
                            Click="NavSavings_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE719;" FontSize="14" Foreground="#AAA"/>
                            <TextBlock Text="Savings &amp; Loans" Foreground="#AAA" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavInvestments"
                            Style="{StaticResource NavItemStyle}"
                            Click="NavInvestments_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14" Foreground="#AAA"/>
                            <TextBlock Text="Investments &amp; Trading" Foreground="#AAA" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavStatistics"
                            Style="{StaticResource NavItemStyle}"
                            Click="NavStatistics_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D2;" FontSize="14" Foreground="#AAA"/>
                            <TextBlock Text="Statistics" Foreground="#AAA" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavSupport"
                            Style="{StaticResource NavItemStyle}"
                            Click="NavSupport_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE897;" FontSize="14" Foreground="#AAA"/>
                            <TextBlock Text="Support" Foreground="#AAA" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavProfile"
                            Style="{StaticResource NavItemStyle}"
                            Click="NavProfile_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE77B;" FontSize="14" Foreground="#AAA"/>
                            <TextBlock Text="Profile" Foreground="#AAA" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>

            <!-- Logout -->
            <Border Grid.Row="2" Padding="8,12,8,20">
                <Button x:Name="LogoutButton"
                        Style="{StaticResource NavItemStyle}"
                        Click="LogoutButton_Click"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xF3B1;" FontSize="14" Foreground="#FF6B6B"/>
                        <TextBlock Text="Log out" Foreground="#FF6B6B" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════
             CONTENT FRAME — views load here
             ═══════════════════════════════════════════════════════ -->
        <Frame x:Name="ContentFrame" Grid.Column="1"/>

    </Grid>
</Page>