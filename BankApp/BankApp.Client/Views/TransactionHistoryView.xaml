<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankApp.Client.Views.TransactionHistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="RootPage"
    RequestedTheme="Light"
    Background="#F4F6FA">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="28" Spacing="18">
                <InfoBar
                    IsOpen="{Binding IsStatusOpen, Mode=TwoWay}"
                    Severity="{Binding StatusSeverity}"
                    Message="{Binding StatusMessage}" />

                <TextBlock Text="Transaction History" FontSize="26" FontWeight="Bold" Foreground="#1A1A2E" />

                <Border Background="White" CornerRadius="18" Padding="18">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Filters" FontSize="18" FontWeight="SemiBold" />

                        <Grid ColumnSpacing="14" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Grid.Column="0" Header="Search" PlaceholderText="Merchant, reference, description" Text="{Binding SearchTerm, Mode=TwoWay}" />
                            <CalendarDatePicker Grid.Row="0" Grid.Column="1" Header="From Date" Date="{Binding FromDate, Mode=TwoWay}" />
                            <CalendarDatePicker Grid.Row="0" Grid.Column="2" Header="To Date" Date="{Binding ToDate, Mode=TwoWay}" />

                            <TextBox Grid.Row="1" Grid.Column="0" Header="Minimum Amount" Text="{Binding MinimumAmountInput, Mode=TwoWay}" />
                            <TextBox Grid.Row="1" Grid.Column="1" Header="Maximum Amount" Text="{Binding MaximumAmountInput, Mode=TwoWay}" />
                            <ComboBox Grid.Row="1" Grid.Column="2" Header="Account" ItemsSource="{Binding AccountOptions}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedAccount, Mode=TwoWay}" />

                            <ComboBox Grid.Row="2" Grid.Column="0" Header="Card" ItemsSource="{Binding CardOptions}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedCard, Mode=TwoWay}" />
                            <ComboBox Grid.Row="2" Grid.Column="1" Header="Type" ItemsSource="{Binding TransactionTypeOptions}" SelectedItem="{Binding SelectedTransactionType, Mode=TwoWay}" />
                            <ComboBox Grid.Row="2" Grid.Column="2" Header="Status" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus, Mode=TwoWay}" />
                        </Grid>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0" Header="Direction" ItemsSource="{Binding DirectionOptions}" SelectedItem="{Binding SelectedDirection, Mode=TwoWay}" />
                            <ComboBox Grid.Column="1" Header="Sort" ItemsSource="{Binding SortFieldOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedSortField, Mode=TwoWay}" />
                            <ComboBox Grid.Column="2" Width="160" Margin="0,24,0,0" ItemsSource="{Binding SortDirectionOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedSortDirection, Mode=TwoWay}" />

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom">
                                <Button Content="Apply" Command="{Binding RefreshCommand}" />
                                <Button Content="Reset" Command="{Binding ResetFiltersCommand}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="18" Padding="18">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Export" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="CSV" Command="{Binding ExportCsvCommand}" />
                            <Button Content="PDF" Command="{Binding ExportPdfCommand}" />
                            <Button Content="XLSX" Command="{Binding ExportXlsxCommand}" />
                        </StackPanel>
                        <TextBlock Text="{Binding LastExportPath}" TextWrapping="Wrap" Foreground="#4E5566" />
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="18" Padding="14" Margin="0,0,18,0">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Transactions" FontSize="18" FontWeight="SemiBold" />
                            <ListView
                                x:Name="TransactionsList"
                                ItemsSource="{Binding Transactions}"
                                SelectionMode="Single"
                                IsItemClickEnabled="True"
                                ItemClick="TransactionsList_ItemClick"
                                SelectionChanged="TransactionsList_SelectionChanged"
                                MinHeight="520"
                                Background="Transparent"
                                BorderThickness="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14" CornerRadius="14" Margin="0,0,0,10" Background="#F8FAFC">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding CounterpartyOrMerchant}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding ReferenceNumber}" Foreground="#4E5566" />
                                                <TextBlock Text="{Binding Timestamp}" Foreground="#4E5566" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="4" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Amount}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding Currency}" HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding Status}" Foreground="#0F766E" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="18" Padding="22">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Details" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock
                                x:Name="EmptyDetailsText"
                                Text="Select a transaction to see its details."
                                Foreground="#5B6170"
                                TextWrapping="Wrap"
                                Visibility="Collapsed" />

                            <StackPanel x:Name="DetailsContentPanel" Spacing="12">
                                <TextBlock x:Name="ReferenceNumberText" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="TimestampText" Foreground="#4E5566" />
                                <TextBlock x:Name="TransactionTypeText" />
                                <TextBlock x:Name="CounterpartyText" />
                                <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" />

                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="6">
                                        <TextBlock Text="Amount" FontWeight="SemiBold" />
                                        <TextBlock x:Name="AmountText" />
                                        <TextBlock Text="Currency" FontWeight="SemiBold" Margin="0,10,0,0" />
                                        <TextBlock x:Name="CurrencyText" />
                                        <TextBlock Text="Direction" FontWeight="SemiBold" Margin="0,10,0,0" />
                                        <TextBlock x:Name="DirectionText" />
                                        <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,10,0,0" />
                                        <TextBlock x:Name="StatusText" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <TextBlock Text="Running Balance" FontWeight="SemiBold" />
                                        <TextBlock x:Name="RunningBalanceText" />
                                        <TextBlock Text="Fee" FontWeight="SemiBold" Margin="0,10,0,0" />
                                        <TextBlock x:Name="FeeText" />
                                        <TextBlock Text="Exchange Rate" FontWeight="SemiBold" Margin="0,10,0,0" />
                                        <TextBlock x:Name="ExchangeRateText" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Source IBAN" FontWeight="SemiBold" Margin="0,10,0,0" />
                                <TextBlock x:Name="SourceIbanText" TextWrapping="Wrap" />
                                <TextBlock Text="Destination IBAN" FontWeight="SemiBold" Margin="0,10,0,0" />
                                <TextBlock x:Name="DestinationIbanText" TextWrapping="Wrap" />
                            </StackPanel>

                            <Button
                                x:Name="DownloadReceiptButton"
                                Content="Download PDF Receipt"
                                Command="{Binding DownloadReceiptCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid Background="#80F4F6FA" Visibility="{Binding LoadingVisibility}">
            <ProgressRing Width="56" Height="56" IsActive="True" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
