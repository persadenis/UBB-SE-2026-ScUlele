<Page

    x:Class="BankApp.Client.Views.ProfileView"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    mc:Ignorable="d"

    Background="#F4F6FA">



    <Page.Resources>



        <!-- ── Colour tokens ── -->

        <SolidColorBrush x:Key="PrimaryBlue"   Color="#1A3C6E"/>

        <SolidColorBrush x:Key="AccentBlue"    Color="#2563EB"/>

        <SolidColorBrush x:Key="LightBlue"     Color="#EFF4FF"/>

        <SolidColorBrush x:Key="CardBg"        Color="#FFFFFF"/>

        <SolidColorBrush x:Key="BorderColor"   Color="#E2E8F0"/>

        <SolidColorBrush x:Key="TextPrimary"   Color="#1E293B"/>

        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>

        <SolidColorBrush x:Key="DangerRed"     Color="#EF4444"/>



        <!-- WinUI TextBox token overrides -->

        <SolidColorBrush x:Key="TextControlForeground"            Color="#1E293B"/>

        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#1E293B"/>

        <SolidColorBrush x:Key="TextControlForegroundFocused"     Color="#1E293B"/>

        <SolidColorBrush x:Key="TextControlForegroundDisabled"    Color="#94A3B8"/>

        <SolidColorBrush x:Key="TextControlBackground"            Color="#F8FAFC"/>

        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#F1F5F9"/>

        <SolidColorBrush x:Key="TextControlBackgroundFocused"     Color="#FFFFFF"/>

        <SolidColorBrush x:Key="TextControlBackgroundDisabled"    Color="#F1F5F9"/>





        <!-- ══════════════════════════════════════════════

             CONTENT BUTTON STYLES

        ═════════════════════════════════════════════════ -->



        <Style x:Key="PrimaryButtonStyle" TargetType="Button">

            <Setter Property="Background"      Value="#2563EB"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Padding"         Value="20,9"/>

            <Setter Property="FontSize"        Value="13"/>

            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>

            <Setter Property="Height"          Value="38"/>

            <Setter Property="CornerRadius"    Value="8"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Root" Background="{TemplateBinding Background}"

                                CornerRadius="{TemplateBinding CornerRadius}"

                                Padding="{TemplateBinding Padding}">

                            <VisualStateManager.VisualStateGroups>

                                <VisualStateGroup x:Name="CommonStates">

                                    <VisualState x:Name="Normal"/>

                                    <VisualState x:Name="PointerOver">

                                        <Storyboard>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">

                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#1D55D4"/>

                                            </ObjectAnimationUsingKeyFrames>

                                        </Storyboard>

                                    </VisualState>

                                    <VisualState x:Name="Pressed">

                                        <Storyboard>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">

                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#1848BC"/>

                                            </ObjectAnimationUsingKeyFrames>

                                        </Storyboard>

                                    </VisualState>

                                    <VisualState x:Name="Disabled">

                                        <Storyboard>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">

                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#93B4F0"/>

                                            </ObjectAnimationUsingKeyFrames>

                                        </Storyboard>

                                    </VisualState>

                                </VisualStateGroup>

                            </VisualStateManager.VisualStateGroups>

                            <ContentPresenter Content="{TemplateBinding Content}"

                                              HorizontalAlignment="Center" VerticalAlignment="Center"

                                              Foreground="White"

                                              FontSize="{TemplateBinding FontSize}"

                                              FontFamily="{TemplateBinding FontFamily}"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <Style x:Key="DangerButtonStyle" TargetType="Button">

            <Setter Property="Background"      Value="#EF4444"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Padding"         Value="20,9"/>

            <Setter Property="FontSize"        Value="13"/>

            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>

            <Setter Property="Height"          Value="38"/>

            <Setter Property="CornerRadius"    Value="8"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Root" Background="{TemplateBinding Background}"

                                CornerRadius="{TemplateBinding CornerRadius}"

                                Padding="{TemplateBinding Padding}">

                            <VisualStateManager.VisualStateGroups>

                                <VisualStateGroup x:Name="CommonStates">

                                    <VisualState x:Name="Normal"/>

                                    <VisualState x:Name="PointerOver">

                                        <Storyboard>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">

                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#DC2626"/>

                                            </ObjectAnimationUsingKeyFrames>

                                        </Storyboard>

                                    </VisualState>

                                    <VisualState x:Name="Pressed">

                                        <Storyboard>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">

                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#B91C1C"/>

                                            </ObjectAnimationUsingKeyFrames>

                                        </Storyboard>

                                    </VisualState>

                                </VisualStateGroup>

                            </VisualStateManager.VisualStateGroups>

                            <ContentPresenter Content="{TemplateBinding Content}"

                                              HorizontalAlignment="Center" VerticalAlignment="Center"

                                              Foreground="White"

                                              FontSize="{TemplateBinding FontSize}"

                                              FontFamily="{TemplateBinding FontFamily}"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <Style x:Key="OutlineButtonStyle" TargetType="Button">

            <Setter Property="Background"      Value="Transparent"/>

            <Setter Property="BorderBrush"     Value="#2563EB"/>

            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Padding"         Value="14,7"/>

            <Setter Property="FontSize"        Value="12"/>

            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>

            <Setter Property="CornerRadius"    Value="7"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Root"

                                Background="{TemplateBinding Background}"

                                BorderBrush="{TemplateBinding BorderBrush}"

                                BorderThickness="{TemplateBinding BorderThickness}"

                                CornerRadius="{TemplateBinding CornerRadius}"

                                Padding="{TemplateBinding Padding}">

                            <VisualStateManager.VisualStateGroups>

                                <VisualStateGroup x:Name="CommonStates">

                                    <VisualState x:Name="Normal"/>

                                    <VisualState x:Name="PointerOver">

                                        <Storyboard>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">

                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#EFF4FF"/>

                                            </ObjectAnimationUsingKeyFrames>

                                        </Storyboard>

                                    </VisualState>

                                    <VisualState x:Name="Pressed">

                                        <Storyboard>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">

                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#DBEAFE"/>

                                            </ObjectAnimationUsingKeyFrames>

                                        </Storyboard>

                                    </VisualState>

                                </VisualStateGroup>

                            </VisualStateManager.VisualStateGroups>

                            <ContentPresenter Content="{TemplateBinding Content}"

                                              HorizontalAlignment="Center" VerticalAlignment="Center"

                                              Foreground="#2563EB"

                                              FontSize="{TemplateBinding FontSize}"

                                              FontFamily="{TemplateBinding FontFamily}"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- Tab inactive -->

        <Style x:Key="TabButtonStyle" TargetType="Button">

            <Setter Property="Background"      Value="Transparent"/>

            <Setter Property="BorderThickness" Value="0,0,0,2"/>

            <Setter Property="BorderBrush"     Value="Transparent"/>

            <Setter Property="Padding"         Value="18,12"/>

            <Setter Property="FontSize"        Value="13"/>

            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Root"

                                Background="{TemplateBinding Background}"

                                BorderBrush="{TemplateBinding BorderBrush}"

                                BorderThickness="{TemplateBinding BorderThickness}"

                                Padding="{TemplateBinding Padding}">

                            <VisualStateManager.VisualStateGroups>

                                <VisualStateGroup x:Name="CommonStates">

                                    <VisualState x:Name="Normal"/>

                                    <VisualState x:Name="PointerOver">

                                        <Storyboard>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">

                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#F8FAFC"/>

                                            </ObjectAnimationUsingKeyFrames>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CP" Storyboard.TargetProperty="Foreground">

                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#1E293B"/>

                                            </ObjectAnimationUsingKeyFrames>

                                        </Storyboard>

                                    </VisualState>

                                </VisualStateGroup>

                            </VisualStateManager.VisualStateGroups>

                            <ContentPresenter x:Name="CP" Content="{TemplateBinding Content}"

                                              HorizontalAlignment="Center" VerticalAlignment="Center"

                                              Foreground="#94A3B8"

                                              FontSize="{TemplateBinding FontSize}"

                                              FontFamily="{TemplateBinding FontFamily}"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- Tab active -->

        <Style x:Key="TabButtonActiveStyle" TargetType="Button">

            <Setter Property="Background"      Value="Transparent"/>

            <Setter Property="BorderThickness" Value="0,0,0,2"/>

            <Setter Property="BorderBrush"     Value="#2563EB"/>

            <Setter Property="Padding"         Value="18,12"/>

            <Setter Property="FontSize"        Value="13"/>

            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Root"

                                Background="{TemplateBinding Background}"

                                BorderBrush="{TemplateBinding BorderBrush}"

                                BorderThickness="{TemplateBinding BorderThickness}"

                                Padding="{TemplateBinding Padding}">

                            <VisualStateManager.VisualStateGroups>

                                <VisualStateGroup x:Name="CommonStates">

                                    <VisualState x:Name="Normal"/>

                                    <VisualState x:Name="PointerOver">

                                        <Storyboard>

                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CP" Storyboard.TargetProperty="Foreground">

                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#1D55D4"/>

                                            </ObjectAnimationUsingKeyFrames>

                                        </Storyboard>

                                    </VisualState>

                                </VisualStateGroup>

                            </VisualStateManager.VisualStateGroups>

                            <ContentPresenter x:Name="CP" Content="{TemplateBinding Content}"

                                              HorizontalAlignment="Center" VerticalAlignment="Center"

                                              Foreground="#2563EB"

                                              FontSize="{TemplateBinding FontSize}"

                                              FontFamily="{TemplateBinding FontFamily}"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- TextBox -->

        <Style x:Key="InputStyle" TargetType="TextBox">

            <Setter Property="Background"      Value="#F8FAFC"/>

            <Setter Property="Foreground"      Value="#1E293B"/>

            <Setter Property="BorderBrush"     Value="#E2E8F0"/>

            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Padding"         Value="10,8"/>

            <Setter Property="FontSize"        Value="13"/>

            <Setter Property="FontFamily"      Value="Segoe UI"/>

            <Setter Property="Height"          Value="36"/>

            <Setter Property="CornerRadius"    Value="6"/>

        </Style>



        <Style x:Key="PasswordStyle" TargetType="PasswordBox">

            <Setter Property="Background"         Value="#F8FAFC"/>

            <Setter Property="Foreground"         Value="#1E293B"/>

            <Setter Property="BorderBrush"        Value="#E2E8F0"/>

            <Setter Property="BorderThickness"    Value="1"/>

            <Setter Property="Padding"            Value="10,8"/>

            <Setter Property="FontSize"           Value="13"/>

            <Setter Property="FontFamily"         Value="Segoe UI"/>

            <Setter Property="Height"             Value="36"/>

            <Setter Property="CornerRadius"       Value="6"/>

            <Setter Property="PasswordRevealMode" Value="Hidden"/>

        </Style>



        <!-- Dialog PasswordBox — slightly taller, white bg for contrast on dialog -->

        <Style x:Key="DialogPasswordStyle" TargetType="PasswordBox">

            <Setter Property="Background"         Value="#FFFFFF"/>

            <Setter Property="Foreground"         Value="#1E293B"/>

            <Setter Property="BorderBrush"        Value="#CBD5E1"/>

            <Setter Property="BorderThickness"    Value="1.5"/>

            <Setter Property="Padding"            Value="12,10"/>

            <Setter Property="FontSize"           Value="13.5"/>

            <Setter Property="FontFamily"         Value="Segoe UI"/>

            <Setter Property="Height"             Value="42"/>

            <Setter Property="CornerRadius"       Value="8"/>

            <Setter Property="PasswordRevealMode" Value="Hidden"/>

        </Style>



        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">

            <Setter Property="FontSize"   Value="12"/>

            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>

            <Setter Property="Foreground" Value="#64748B"/>

            <Setter Property="Margin"     Value="0,0,0,5"/>

        </Style>



        <!-- Larger label used inside dialogs -->

        <Style x:Key="DialogFieldLabelStyle" TargetType="TextBlock">

            <Setter Property="FontSize"   Value="12.5"/>

            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>

            <Setter Property="Foreground" Value="#475569"/>

            <Setter Property="Margin"     Value="0,0,0,6"/>

        </Style>



        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">

            <Setter Property="FontSize"   Value="14"/>

            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>

            <Setter Property="Foreground" Value="#1E293B"/>

        </Style>



    </Page.Resources>


    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <!-- ════════════════════  MAIN CONTENT  ════════════════════ -->

        <ScrollViewer
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              VerticalScrollMode="Enabled"
              VerticalContentAlignment="Top">

            <Grid Margin="28,22,28,28" VerticalAlignment="Top">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="16"/>

                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>



                <!-- Page title -->

                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBlock Text="Profile"

                               FontSize="22" FontFamily="Segoe UI Semibold" Foreground="#1E293B"/>

                    <TextBlock Text=" / Settings"

                               FontSize="22" FontFamily="Segoe UI" Foreground="#94A3B8"/>

                </StackPanel>



                <!-- InfoBars -->

                <StackPanel Grid.Row="1" Margin="0,10,0,0" Spacing="6">

                    <StackPanel x:Name="LoadingPanel" Orientation="Horizontal" Visibility="Collapsed">

                        <ProgressRing x:Name="LoadingRing" IsActive="False"

                                      Width="20" Height="20"

                                      Foreground="#2563EB" Margin="0,0,8,0"/>

                        <TextBlock Text="Saving changes…" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>

                    </StackPanel>

                    <InfoBar x:Name="ErrorInfoBar"   Severity="Error"   IsOpen="False" IsClosable="True"/>

                    <InfoBar x:Name="SuccessInfoBar" Severity="Success" IsOpen="False" IsClosable="True"/>

                </StackPanel>



                <!-- Body -->

                <Grid Grid.Row="3">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="210"/>

                        <ColumnDefinition Width="18"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>



                    <!-- ─────────────────────  PROFILE CARD  ───────────────────── -->

                    <Border Grid.Column="0"

                            Background="White"

                            CornerRadius="16"

                            Padding="0,0,0,20"

                            VerticalAlignment="Top">

                        <Border.Shadow>

                            <ThemeShadow/>

                        </Border.Shadow>



                        <StackPanel>

                            <!-- Blue gradient header strip -->

                            <Border CornerRadius="16,16,0,0" Padding="16,20,16,22">

                                <Border.Background>

                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">

                                        <GradientStop Color="#16213E" Offset="0"/>

                                        <GradientStop Color="#4169E1" Offset="1"/>

                                    </LinearGradientBrush>

                                </Border.Background>

                                <StackPanel HorizontalAlignment="Center">

                                    <Border Width="64" Height="64" CornerRadius="32"

                                            Background="#7393B3"

                                            HorizontalAlignment="Center"

                                            Margin="0,0,0,10">

                                        <FontIcon Glyph="&#xE77B;" FontFamily="Segoe MDL2 Assets"

                                                  FontSize="28" Foreground="White"

                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                    </Border>

                                    <TextBlock x:Name="ProfileCardName"

                                               FontSize="14" FontFamily="Segoe UI Semibold"

                                               Foreground="White"

                                               HorizontalAlignment="Center" TextAlignment="Center"/>

                                </StackPanel>

                            </Border>



                            <!-- Details -->

                            <StackPanel Margin="16,14,16,0" Spacing="10">

                                <StackPanel>

                                    <TextBlock Text="EMAIL" Style="{StaticResource FieldLabelStyle}"

                                               FontSize="10" Foreground="#94A3B8"/>

                                    <TextBlock x:Name="ProfileCardEmail"

                                               FontSize="12" Foreground="#1E293B"

                                               TextTrimming="CharacterEllipsis"/>

                                </StackPanel>

                                <Border Height="1" Background="#F1F5F9"/>

                                <StackPanel>

                                    <TextBlock Text="PHONE" Style="{StaticResource FieldLabelStyle}"

                                               FontSize="10" Foreground="#94A3B8"/>

                                    <TextBlock x:Name="ProfileCardPhone"

                                               FontSize="12" Foreground="#1E293B"/>

                                </StackPanel>

                                <Border Height="1" Background="#F1F5F9"/>

                                <StackPanel>

                                    <TextBlock Text="ADDRESS" Style="{StaticResource FieldLabelStyle}"

                                               FontSize="10" Foreground="#94A3B8"/>

                                    <TextBlock x:Name="ProfileCardAddress"

                                               FontSize="12" Foreground="#1E293B"

                                               TextWrapping="Wrap"/>

                                </StackPanel>

                            </StackPanel>

                        </StackPanel>

                    </Border>



                    <!-- ─────────────────────  TAB PANEL  ───────────────────── -->

                    <Border Grid.Column="2" Background="White" CornerRadius="16" VerticalAlignment="Top">

                        <Border.Shadow>

                            <ThemeShadow/>

                        </Border.Shadow>

                        <StackPanel>



                            <!-- Tab header bar with subtle gradient -->

                            <Border CornerRadius="16,16,0,0" Padding="6,0">

                                <Border.Background>

                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">

                                        <GradientStop Color="#FFFFFF" Offset="0"/>

                                        <GradientStop Color="#F8FAFC" Offset="1"/>

                                    </LinearGradientBrush>

                                </Border.Background>

                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">

                                    <StackPanel Orientation="Horizontal">

                                        <Button x:Name="TabPersonalBtn"

                                                Content="Personal Information"

                                                Style="{StaticResource TabButtonActiveStyle}"

                                                Click="TabPersonalBtn_Click"/>

                                        <Button x:Name="TabSecurityBtn"

                                                Content="Security Settings"

                                                Style="{StaticResource TabButtonStyle}"

                                                Click="TabSecurityBtn_Click"/>

                                        <Button x:Name="TabNotificationsBtn"

                                                Content="Notification Preferences"

                                                Style="{StaticResource TabButtonStyle}"

                                                Click="TabNotificationsBtn_Click"/>

                                    </StackPanel>

                                </Border>

                            </Border>



                            <!-- Tab content -->

                            <Grid Margin="26,22,26,26">



                                <!-- ══════════════════════  TAB 1 — Personal Info  ══════════════════════ -->

                                <StackPanel x:Name="PanelPersonal" Visibility="Visible" Spacing="0">



                                    <!-- Section header -->

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">

                                        <Border Width="36" Height="36" CornerRadius="10"

                Background="#EFF4FF" Margin="0,0,12,0">

                                            <FontIcon Glyph="&#xE77B;" FontFamily="Segoe MDL2 Assets"

                      FontSize="16" Foreground="#2563EB"

                      HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                        </Border>

                                        <StackPanel VerticalAlignment="Center">

                                            <TextBlock Text="Personal Information"

                       FontSize="15" FontFamily="Segoe UI Semibold"

                       Foreground="#1E293B"/>

                                            <TextBlock Text="View and update your personal details"

                       FontSize="12" Foreground="#94A3B8"/>

                                        </StackPanel>

                                    </StackPanel>



                                    <!-- Fields -->

                                    <Border Background="#FAFBFF" CornerRadius="12"

            BorderBrush="#E2E8F0" BorderThickness="1"

            Padding="20,18" Margin="0,0,0,16">

                                        <StackPanel Spacing="14">



                                            <!-- Row 1 -->

                                            <Grid>

                                                <Grid.ColumnDefinitions>

                                                    <ColumnDefinition Width="*"/>

                                                    <ColumnDefinition Width="16"/>

                                                    <ColumnDefinition Width="*"/>

                                                </Grid.ColumnDefinitions>



                                                <StackPanel Grid.Column="0">

                                                    <TextBlock Text="Full Name" Style="{StaticResource FieldLabelStyle}"/>

                                                    <TextBox x:Name="FullNameBox"

                             Style="{StaticResource InputStyle}"

                             IsReadOnly="True"

                             Opacity="0.6"/>

                                                </StackPanel>



                                                <StackPanel Grid.Column="2">

                                                    <TextBlock Text="Email Address" Style="{StaticResource FieldLabelStyle}"/>

                                                    <TextBox x:Name="EmailBox"

                             Style="{StaticResource InputStyle}"

                             IsReadOnly="True"

                             Opacity="0.6"/>

                                                </StackPanel>

                                            </Grid>



                                            <!-- Row 2 -->

                                            <Grid>

                                                <Grid.ColumnDefinitions>

                                                    <ColumnDefinition Width="*"/>

                                                    <ColumnDefinition Width="16"/>

                                                    <ColumnDefinition Width="*"/>

                                                </Grid.ColumnDefinitions>



                                                <StackPanel Grid.Column="0">

                                                    <TextBlock Text="Phone Number" Style="{StaticResource FieldLabelStyle}"/>

                                                    <TextBox x:Name="PhoneBox"

                             Style="{StaticResource InputStyle}"

                             IsReadOnly="True"

                             Opacity="0.6"/>

                                                </StackPanel>



                                                <StackPanel Grid.Column="2">

                                                    <TextBlock Text="Address" Style="{StaticResource FieldLabelStyle}"/>

                                                    <TextBox x:Name="AddressBox"

                             Style="{StaticResource InputStyle}"

                             IsReadOnly="True"

                             Opacity="0.6"/>

                                                </StackPanel>

                                            </Grid>



                                        </StackPanel>

                                    </Border>



                                    <!-- Info note -->

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">

                                        <FontIcon Glyph="&#xE783;" FontFamily="Segoe MDL2 Assets"

                  FontSize="11" Foreground="#94A3B8" Margin="0,0,6,0"/>

                                        <TextBlock Text="You must verify your password before editing your information."

                   FontSize="11.5" Foreground="#94A3B8"

                   TextWrapping="Wrap"/>

                                    </StackPanel>



                                    <!-- Buttons -->

                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" 
                                                x:Name="UpdateButton"
                                                Style="{StaticResource OutlineButtonStyle}"
                                                Content="Unlock Update"
                                                HorizontalAlignment="Stretch"
                                                Height="40"
                                                Click="UpdateButton_Click"/>

                                        <Button Grid.Column="1" 
                                                x:Name="SaveButton"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Content="Save Changes"
                                                HorizontalAlignment="Stretch"
                                                Height="40"
                                                IsEnabled="False"
                                                Click="SaveButton_Click"/>
                                    </Grid>



                                </StackPanel>



                                <StackPanel x:Name="PanelSecurity" Visibility="Collapsed" Spacing="14">

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Width="36" Height="36" CornerRadius="10" Background="#EFF4FF" Margin="0,0,12,0">
                                            <FontIcon Glyph="&#xE72E;" FontSize="16" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Security Settings" FontSize="15" FontFamily="Segoe UI Semibold" Foreground="#1E293B"/>
                                            <TextBlock Text="Manage your authentication and password" FontSize="12" Foreground="#94A3B8"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Background="#FAFBFF" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                                        <StackPanel Spacing="20">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="36" Height="36" CornerRadius="10" Background="#EFF4FF" Margin="0,0,12,0">
                                                    <FontIcon Glyph="&#xE8EA;" FontSize="16" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Two-Factor Authentication" Style="{StaticResource SectionTitleStyle}"/>
                                                    <TextBlock Text="Methods must be verified before they can be used for security." FontSize="11" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Border Height="1" Background="#F1F5F9"/>

                                            <!-- 2FA Master Toggle -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE8EA;" FontSize="18" Foreground="#64748B" Margin="0,0,15,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="Enable Two-Factor Authentication" FontSize="13" Foreground ="#1E293B"  FontFamily="Segoe UI Semibold"/>
                                                    <TextBlock Text="Require a verification code when signing in" FontSize="12" Foreground="#94A3B8"/>
                                                </StackPanel>
                                                <ToggleSwitch x:Name="TwoFactorToggle"
                                                              Grid.Column="2"
                                                              OnContent="" OffContent=""
                                                              VerticalAlignment="Center"
                                                              Toggled="TwoFactorToggle_Toggled"/>
                                            </Grid>

                                            <Border Height="1" Background="#F1F5F9"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE717;" FontSize="18" Foreground="#64748B" Margin="0,0,15,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Phone Verification" FontSize="13" FontFamily="Segoe UI Semibold"/>
                                                        <Border x:Name="PhoneStatusBadge" Margin="8,0,0,0" Padding="6,1" CornerRadius="4" Background="#F1F5F9">
                                                            <TextBlock x:Name="PhoneStatusText" Text="Unverified" FontSize="10" Foreground="#64748B"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock x:Name="TwoFactorPhoneDisplay" Text="Not configured" FontSize="12" Foreground="#94A3B8"/>
                                                </StackPanel>
                                                <Button x:Name="ActionPhoneBtn" Grid.Column="2" Content="Verify" 
                        Style="{StaticResource OutlineButtonStyle}" Width="80"
                        Click="Handle2FAAction_Click" Tag="Phone"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE715;" FontSize="18" Foreground="#64748B" Margin="0,0,15,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Email Verification" FontSize="13" FontFamily="Segoe UI Semibold"/>
                                                        <Border x:Name="EmailStatusBadge" Margin="8,0,0,0" Padding="6,1" CornerRadius="4" Background="#F1F5F9">
                                                            <TextBlock x:Name="EmailStatusText" Text="Unverified" FontSize="10" Foreground="#64748B"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock x:Name="TwoFactorEmailDisplay" Text="Not configured" FontSize="12" Foreground="#94A3B8"/>
                                                </StackPanel>
                                                <Button x:Name="ActionEmailBtn" Grid.Column="2" Content="Verify" 
                        Style="{StaticResource OutlineButtonStyle}" Width="80"
                        Click="Handle2FAAction_Click" Tag="Email"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FAFBFF" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="18,16">
                                        <StackPanel Spacing="12">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="30" Height="30" CornerRadius="8" Background="#EFF4FF" Margin="0,0,10,0">
                                                    <FontIcon Glyph="&#xE8FD;" FontSize="14" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Connected Accounts" Style="{StaticResource SectionTitleStyle}" FontSize="13.5"/>
                                                    <TextBlock Text="Manage third-party sign-in providers" FontSize="11.5" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Height="1" Background="#E2E8F0"/>
                                            <StackPanel x:Name="OAuthLinksPanel"/>
                                            <Button x:Name="ManageDevicesButton" Style="{StaticResource OutlineButtonStyle}" HorizontalAlignment="Left" Click="ManageDevicesButton_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <FontIcon Glyph="&#xE8FA;" FontSize="11" Margin="0,0,6,0" Foreground="#2563EB"/>
                                                    <TextBlock Text="Manage Connected Accounts" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <Border CornerRadius="12" BorderThickness="1" BorderBrush="#FECACA" Padding="18,16">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FFF5F5" Offset="0"/>
                                                <GradientStop Color="#FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                                                <Border Width="30" Height="30" CornerRadius="8" Background="#FEE2E2" Margin="0,0,10,0">
                                                    <FontIcon Glyph="&#xE72E;" FontSize="14" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Password Settings" Style="{StaticResource SectionTitleStyle}" FontSize="13.5"/>
                                                    <TextBlock Text="Change your account password" FontSize="11.5" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button x:Name="ChangePasswordButton" Grid.Column="1" Style="{StaticResource DangerButtonStyle}" VerticalAlignment="Center" Click="ChangePasswordButton_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <FontIcon Glyph="&#xE72E;" FontSize="12" Margin="0,0,7,0" Foreground="White"/>
                                                    <TextBlock Text="Change Password" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                <StackPanel x:Name="PanelNotifications" Visibility="Collapsed">





                                    <!-- ══════════════════════  TAB 3 — Notifications  ══════════════════════ -->

                                    <!-- Section header -->

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">

                                        <Border Width="36" Height="36" CornerRadius="10"

                                                Background="#EFF4FF" Margin="0,0,12,0">

                                            <FontIcon Glyph="&#xE7E7;" FontFamily="Segoe MDL2 Assets"

                                                      FontSize="16" Foreground="#2563EB"

                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                        </Border>

                                        <StackPanel VerticalAlignment="Center">

                                            <TextBlock Text="Notification Preferences"

                                                       FontSize="15" FontFamily="Segoe UI Semibold"

                                                       Foreground="#1E293B"/>

                                            <TextBlock Text="Choose which alerts you want to receive"

                                                       FontSize="12" Foreground="#94A3B8"/>

                                        </StackPanel>

                                    </StackPanel>



                                    <Border BorderBrush="#E2E8F0" BorderThickness="1"

                                            CornerRadius="12" Padding="20,6" Background="#FAFBFF">

                                        <StackPanel x:Name="NotificationPreferencesPanel"/>

                                    </Border>

                                </StackPanel>



                            </Grid>

                        </StackPanel>

                    </Border>



                </Grid>

            </Grid>

        </ScrollViewer>



        <!-- ══════════════════════════════════════════════════

             STEP 1 — VERIFY CURRENT PASSWORD DIALOG

        ═══════════════════════════════════════════════════ -->

        <ContentDialog x:Name="VerifyPasswordDialog"

                       PrimaryButtonText="Continue"

                       SecondaryButtonText="Cancel"

                       DefaultButton="Primary"

                       PrimaryButtonClick="VerifyPasswordDialog_PrimaryButtonClick"

                       CornerRadius="16">

            <ContentDialog.Resources>

                <SolidColorBrush x:Key="ContentDialogBackground" Color="#F8FAFC"/>
                <SolidColorBrush x:Key="ContentDialogForeground" Color="#1E293B"/>
                <SolidColorBrush x:Key="ButtonForeground" Color="#1E293B"/>

                <Style x:Key="DialogSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource OutlineButtonStyle}">
                    <Setter Property="MinWidth" Value="90"/>
                </Style>

                <Style x:Key="DialogPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                    <Setter Property="MinWidth" Value="110"/>
                </Style>

            </ContentDialog.Resources>



            <!--

                Scrollable content so the dialog is never clipped on small screens.

                Max height keeps it compact on large screens.

            -->

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="520">

                <StackPanel Width="360" Spacing="0">



                    <!-- Custom header area — lock icon + title + subtitle -->

                    <Border Background="White" CornerRadius="12,12,0,0" Padding="24,22,24,20"

                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Margin="0,0,0,20">

                        <StackPanel Orientation="Horizontal">

                            <Border Width="44" Height="44" CornerRadius="12"

                                    Background="#FEE2E2" Margin="0,0,14,0">

                                <FontIcon Glyph="&#xE72E;" FontFamily="Segoe MDL2 Assets"

                                          FontSize="20" Foreground="#EF4444"

                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            </Border>

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock Text="Verify Your Identity"

                                           FontSize="16" FontFamily="Segoe UI Semibold"

                                           Foreground="#1E293B"/>

                                <TextBlock Text="Confirm your password to continue"

                                           FontSize="12" Foreground="#94A3B8"/>

                            </StackPanel>

                        </StackPanel>

                    </Border>



                    <!-- Body -->

                    <StackPanel Padding="24,0,24,24" Spacing="16">



                        <InfoBar x:Name="VerifyErrorInfoBar"

                                 Severity="Error" IsOpen="False" IsClosable="False"/>



                        <StackPanel Spacing="6">

                            <TextBlock Text="Current Password" Style="{StaticResource DialogFieldLabelStyle}"/>

                            <PasswordBox x:Name="VerifyCurrentPasswordBox"

                                         Style="{StaticResource DialogPasswordStyle}"

                                         PlaceholderText="Enter your current password"/>

                        </StackPanel>



                        <!-- Security hint -->

                        <Border Background="#EFF4FF" CornerRadius="8" Padding="12,10">

                            <StackPanel Orientation="Horizontal">

                                <FontIcon Glyph="&#xE946;" FontFamily="Segoe MDL2 Assets"

                                          FontSize="13" Foreground="#2563EB" Margin="0,0,8,0"

                                          VerticalAlignment="Center"/>

                                <TextBlock Text="Your identity is verified"

                                           FontSize="11.5" Foreground="#1D4ED8"

                                           TextWrapping="Wrap" VerticalAlignment="Center"/>

                            </StackPanel>

                        </Border>



                    </StackPanel>

                </StackPanel>

            </ScrollViewer>

        </ContentDialog>



        <!-- ══════════════════════════════════════════════════

             STEP 2 — SET NEW PASSWORD DIALOG

        ═══════════════════════════════════════════════════ -->

        <ContentDialog x:Name="NewPasswordDialog"

                       PrimaryButtonText="Update Password"

                       CloseButtonText="Cancel"

                       DefaultButton="Primary"

                       PrimaryButtonClick="NewPasswordDialog_PrimaryButtonClick"

                       CornerRadius="16">

            <ContentDialog.Resources>

                <SolidColorBrush x:Key="ContentDialogBackground" Color="#F8FAFC"/>

            </ContentDialog.Resources>



            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="520">

                <StackPanel Width="380" Spacing="0">



                    <!-- Custom header -->

                    <Border Background="White" CornerRadius="12,12,0,0" Padding="24,22,24,20"

                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Margin="0,0,0,20">

                        <StackPanel Orientation="Horizontal">

                            <Border Width="44" Height="44" CornerRadius="12"

                                    Background="#EFF4FF" Margin="0,0,14,0">

                                <FontIcon Glyph="&#xE8D7;" FontFamily="Segoe MDL2 Assets"

                                          FontSize="20" Foreground="#2563EB"

                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            </Border>

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock Text="Set New Password"

                                           FontSize="16" FontFamily="Segoe UI Semibold"

                                           Foreground="#1E293B"/>

                                <TextBlock Text="Choose a strong password for your account"

                                           FontSize="12" Foreground="#94A3B8"/>

                            </StackPanel>

                        </StackPanel>

                    </Border>



                    <!-- Body -->

                    <StackPanel Padding="24,0,24,24" Spacing="16">



                        <InfoBar x:Name="NewPasswordErrorInfoBar"

                                 Severity="Error" IsOpen="False" IsClosable="False"/>



                        <StackPanel Spacing="6">

                            <TextBlock Text="New Password" Style="{StaticResource DialogFieldLabelStyle}"/>

                            <PasswordBox x:Name="NewPasswordBox"

                                         Style="{StaticResource DialogPasswordStyle}"

                                         PlaceholderText="Enter new password"/>

                        </StackPanel>



                        <StackPanel Spacing="6">

                            <TextBlock Text="Confirm Password" Style="{StaticResource DialogFieldLabelStyle}"/>

                            <PasswordBox x:Name="ConfirmPasswordBox"

                                         Style="{StaticResource DialogPasswordStyle}"

                                         PlaceholderText="Re-enter new password"/>

                        </StackPanel>



                        <!-- Password rules hint -->

                        <Border Background="#F8FAFC" CornerRadius="8"

                                BorderBrush="#E2E8F0" BorderThickness="1" Padding="14,12">

                            <StackPanel Spacing="6">

                                <StackPanel Orientation="Horizontal">

                                    <FontIcon Glyph="&#xE73E;" FontFamily="Segoe MDL2 Assets"

                                              FontSize="11" Foreground="#64748B" Margin="0,0,7,0"

                                              VerticalAlignment="Center"/>

                                    <TextBlock Text="Minimum 8 characters"

                                               FontSize="12" Foreground="#64748B"/>

                                </StackPanel>

                                <StackPanel Orientation="Horizontal">

                                    <FontIcon Glyph="&#xE73E;" FontFamily="Segoe MDL2 Assets"

                                              FontSize="11" Foreground="#64748B" Margin="0,0,7,0"

                                              VerticalAlignment="Center"/>

                                    <TextBlock Text="Mix of letters, numbers and symbols"

                                               FontSize="12" Foreground="#64748B"/>

                                </StackPanel>

                            </StackPanel>

                        </Border>



                    </StackPanel>

                </StackPanel>

            </ScrollViewer>

        </ContentDialog>



    </Grid>

</Page>